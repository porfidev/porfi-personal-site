---
import './ContactSection.styles.css';
import ContactForm from '../ContactForm/ContactForm.astro';
---

<section id="contact" class="contact">
	<div class="contact__header">
		<div>
			<h1 class="contact__h1">Contacto</h1>
			<p class="contact__p">
				<strong>¿Tienes algo en mente?</strong><br />
				Será un gusto leerte. Ya sea una duda, una propuesta o simplemente quieras iniciar una
				conversación, este espacio está abierto para ti.
			</p>
			<p class="contact__p">Déjame un mensaje y te responderé lo antes posible.</p>
		</div>
	</div>
	<div class="contact__container">
		<ContactForm />

		<div class="contact__cards">
			<div class="contact__card contact__card--wide"></div>
			<div class="contact__card"></div>
			<div class="contact__card"></div>
			<div class="contact__card contact__card--wide"></div>
		</div>
	</div>
</section>
