---
import './ContactSection.styles.css';
import ContactForm from '../ContactForm/ContactForm.astro';
import { contactCopy, type ContactLang } from '../../i18n/contact.ts';

interface Props {
	lang: ContactLang;
}

const { lang } = Astro.props;
const copy = contactCopy[lang];
---

<section id="contact" class="contact">
	<div class="contact__header">
		<div>
			<h1 class="contact__h1">{copy.title}</h1>
			<p class="contact__p">
				<strong>{copy.leadTitle}</strong><br />
				{copy.leadBody}
			</p>
			<p class="contact__p">{copy.note}</p>
		</div>
	</div>
	<div class="contact__container">
		<ContactForm copy={copy.form} />

		<div class="contact__cards">
			<div class="contact__card contact__card--wide"></div>
			<div class="contact__card"></div>
			<div class="contact__card"></div>
			<div class="contact__card contact__card--wide"></div>
		</div>
	</div>
</section>
