root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2
max_line_length = 100

[{*.astro,*.html}]
indent_style = tab
indent_size = 4

[{*.json,*.jsonc,*.yaml,*.yml}]
indent_size = 2

[*.md]
indent_size = 2
trim_trailing_whitespace = false

[*.svg]
indent_size = 2

[Makefile]
indent_style = tab
